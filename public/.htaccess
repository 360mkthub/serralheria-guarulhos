# Este arquivo deve espelhar o public_html/.htaccess gerenciado pela Hostinger
# para evitar regressão de deploy/entrypoint entre repositório e produção.
PassengerAppRoot /home/u236560328/domains/serralheriaemguarulhos.com/nodejs
PassengerAppType node
PassengerNodejs /opt/alt/alt-nodejs22/root/bin/node
PassengerStartupFile server.js
PassengerBaseURI /
PassengerRestartDir /home/u236560328/domains/serralheriaemguarulhos.com/nodejs/tmp
SetEnv NODE_OPTIONS "--require /home/u236560328/domains/serralheriaemguarulhos.com/public_html/.builds/config/preload-timestamp.js"
SetEnv LSNODE_CONSOLE_LOG console.log
SetEnv TOKIO_WORKER_THREADS 2
RewriteRule ^\.builds - [F,L]
